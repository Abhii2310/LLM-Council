# Backend environment variables
# Copy to .env and fill values

GROQ_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=

# Optional
BACKEND_CORS_ORIGINS=http://localhost:5173
REQUEST_TIMEOUT_SECONDS=45
SQLITE_DB_PATH=data/llm_council.sqlite3
CHATGPT_ENABLED=true
CHATGPT_MODEL=openai/gpt-4o-mini

# Local Phase-1 RAG (dependency-free)
RAG_ENABLED=true
RAG_DOCS_PATH=knowledge_base
RAG_CHUNK_SIZE=900
RAG_CHUNK_OVERLAP=150
RAG_TOP_K=4
